{
  "routes": [
    { "src": "/sw.js", "headers": { "Cache-Control": "no-cache, no-store, must-revalidate", "Content-Type": "application/javascript" }, "continue": true },
    { "src": "/manifest.json", "headers": { "Content-Type": "application/manifest+json" }, "continue": true },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
